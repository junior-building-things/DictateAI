{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DictateAI",
  "version": "1.0.5",
  "identifier": "com.dictateai.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "DictateAI",
        "label": "main",
        "width": 920,
        "height": 600,
        "resizable": true,
        "visible": true,
        "center": true
      },
      {
        "title": "",
        "label": "overlay",
        "width": 260,
        "height": 72,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
